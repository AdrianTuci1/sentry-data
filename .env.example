# ─── Required Secrets (generate with: openssl rand -base64 32) ───
JWT_SECRET=
INTERNAL_TOKEN=

# ─── GCP ───
GCP_PROJECT_ID=
GCP_REGION=europe-west1
GCP_KEY_PATH=~/.config/gcloud/application_default_credentials.json

# ─── GCS (created by Terraform) ───
GCS_BUCKET_NAME=sentry-platform-data
GCS_LANDING_ZONE_PREFIX=landing_zone
GCS_AGENT_SNAPSHOTS_PREFIX=agent_snapshots
GCS_SESSION_FILES_PREFIX=session_files

# ─── BigQuery ───
BIGQUERY_LOCATION=EU
BIGQUERY_DATASET_PREFIX=sentry_dataset

# ─── Backend (Express, :3000) ───
PORT=3000
NODE_ENV=production
API_PREFIX=/api/v1
CORS_ORIGIN=*

# ─── Internal Services (Docker network hostnames) ───
CHAT_SERVICE_URL=http://chat:8080
HARNESS_SERVICE_URL=http://harness:8081
OBSERVER_SERVICE_URL=http://observer:8082

# ─── Auth Mode: disabled = no OIDC IAM (VPS-only) ───
CLOUD_RUN_AUTH_MODE=disabled

# ─── LLM (shared by Chat + Harness) ───
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_MODEL_ID=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com/v1

# ─── Backend URL (used by Chat / Observer to call backend) ───
BACKEND_URL=http://backend:3000/api/v1

# ─── Chat → Harness / Observer (internal Docker network) ───
HARNESS_SERVICE_URL=http://harness:8081
OBSERVER_SERVICE_URL=http://observer:8082

# ─── Feature Flags ───
ENABLE_MODAL_AGENTS=false
ENABLE_BIGQUERY_ANALYTICS=true

# ─── Stripe (optional) ───
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ─── Google OAuth (optional) ───
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback
# FRONTEND_URL=http://localhost:5173
