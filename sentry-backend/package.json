{
  "name": "sentry-backend",
  "version": "1.0.0",
  "description": "Sentry Data Backend Node.js Server",
  "main": "dist/app.js",
  "scripts": {
    "build": "npm run build:packages && tsc",
    "build:packages": "tsc -p ../packages/sentinel-core/tsconfig.json && tsc -p ../packages/sentinel-domain-packs/tsconfig.json && tsc -p ../packages/connector-sdk/tsconfig.json && tsc -p ../packages/observability/tsconfig.json && tsc -p ../packages/pne-core/tsconfig.json && tsc -p ../packages/codex-adapter/tsconfig.json && tsc -p ../packages/agent-playbooks/tsconfig.json && tsc -p ../packages/widget-contracts/tsconfig.json && tsc -p ../packages/ml-contracts/tsconfig.json && tsc -p ../packages/powerbi-adapter/tsconfig.json",
    "start": "node dist/app.js",
    "dev": "nodemon src/server.ts",
    "deploy:widgets": "ts-node scripts/sync_widgets.ts",
    "deploy:pne": "ts-node scripts/upload_pne_dist.ts",
    "refresh:check": "ts-node scripts/check_source_updates.ts",
    "seed": "ts-node scripts/seed_test_data.ts",
    "clean": "ts-node scripts/cleanup_runtime_findings.ts",
    "clean:all": "ts-node scripts/full_cleanup.ts",
    "clean:preserve-system": "PRESERVE_R2_SYSTEM=true ts-node scripts/full_cleanup.ts",
    "clean:runtime-findings": "ts-node scripts/cleanup_runtime_findings.ts",
    "runtime": "ts-node scripts/test_runtime.ts",
    "test": "ts-node scripts/test_runtime.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.556.0",
    "@aws-sdk/client-eventbridge": "^3.556.0",
    "@aws-sdk/client-s3": "^3.556.0",
    "@aws-sdk/client-sfn": "^3.556.0",
    "@aws-sdk/lib-dynamodb": "^3.556.0",
    "@aws-sdk/s3-request-presigner": "^3.556.0",
    "@statsparrot/sentinel-core": "file:../packages/sentinel-core",
    "@statsparrot/sentinel-domain-packs": "file:../packages/sentinel-domain-packs",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "e2b": "^2.12.0",
    "esbuild": "^0.27.4",
    "express": "^4.19.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
