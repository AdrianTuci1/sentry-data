# ============================================
# Sentry Backend - Environment Configuration
# ============================================

# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# GCP
GCP_PROJECT_ID=your-project-id
GCP_REGION=europe-west1

# GCS
GCS_BUCKET_NAME=sentry-platform-data
GCS_LANDING_ZONE_PREFIX=landing_zone
GCS_AGENT_SNAPSHOTS_PREFIX=agent_snapshots
GCS_SESSION_FILES_PREFIX=session_files

# BigQuery
BIGQUERY_LOCATION=EU
BIGQUERY_DATASET_PREFIX=sentry_dataset

# Modal
MODAL_WEBHOOK_SECRET=your-modal-secret
MODAL_API_URL=https://your-modal-app.modal.run

# Meltano
MELTANO_API_URL=http://localhost:5000
MELTANO_WEBHOOK_SECRET=your-meltano-secret

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Security
CORS_ORIGIN=http://localhost:3001

# Feature Flags
ENABLE_MODAL_AGENTS=true
ENABLE_MELTANO_INGESTION=true
ENABLE_BIGQUERY_ANALYTICS=true
