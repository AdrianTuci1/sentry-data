# MELTANO SECRETS TEMPLATE
# These values will be injected at runtime per project from your Central Server/DynamoDB

# --- Target: Cloudflare R2 (S3 Compatible) ---
# TARGET_PARQUET_DESTINATION_PATH=s3://your-bucket/bronze/project_id
# TARGET_PARQUET_S3_REGION_NAME=auto
# TARGET_PARQUET_S3_ENDPOINT_URL=https://your-r2-id.r2.cloudflarestorage.com
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# --- Tap: Stripe ---
# TAP_STRIPE_API_KEY=sk_test_...

# --- Tap: Postgres / MySQL ---
# TAP_POSTGRES_HOST=
# TAP_POSTGRES_PORT=5432
# TAP_POSTGRES_USER=
# TAP_POSTGRES_PASSWORD=
# TAP_POSTGRES_DBNAME=

# --- Tap: Meta Ads (Facebook) ---
# TAP_FACEBOOK_ACCESS_TOKEN=
# TAP_FACEBOOK_ACCOUNT_ID=

# --- Tap: Google Ads ---
# TAP_GOOGLEADS_DEVELOPER_TOKEN=
# TAP_GOOGLEADS_CLIENT_ID=
# TAP_GOOGLEADS_CLIENT_SECRET=
# TAP_GOOGLEADS_REFRESH_TOKEN=
# TAP_GOOGLEADS_CUSTOMER_ID=
