{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": "src",
    "paths": {
      "@statsparrot/connector-sdk": [
        "../../connector-sdk/dist"
      ],
      "@statsparrot/observability": [
        "../../observability/dist"
      ],
      "@statsparrot/sentinel-core": [
        "../../sentinel-core/dist"
      ]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
